@page "/home"
@attribute [Authorize]
@using GoodHamburger.BlazorApp.Services
@using GoodHamburger.BlazorApp.Models
@using Microsoft.AspNetCore.Authorization
@inject IMenuService MenuService
@inject IOrderService OrderService
@inject ToastService ToastService

<PageTitle>GoodHamburger - Faça seu Pedido</PageTitle>

<div class="container">
    <h1><i class="bi bi-shop" style="font-size: 0.9em;"></i> GoodHamburger</h1>
    <p style="text-align: center; color: white; font-size: 1.2em; margin-top: -10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">
        Monte seu combo perfeito e aproveite nossos descontos!
    </p>

    @if (loading)
    {
        <div class="loading">
            <div class="loading-spinner"></div>
            <div class="loading-text">Carregando cardápio...</div>
        </div>
    }
    else if (error != null)
    {
        <div class="error">@error</div>
    }
    else
    {
        <h2>Cardápio</h2>
        <div class="menu-grid">
            @foreach (var item in menuItems)
            {
                <div class="menu-item @(selectedItems.Contains(item.Id) ? "selected" : "")" 
                     @onclick="() => ToggleItem(item)">
                    <span class="badge @GetBadgeClass(item.Type)">@GetTypeLabel(item.Type)</span>
                    <h3>@item.Name</h3>
                    <div class="price">R$ @item.Price.ToString("F2")</div>
                    @if (selectedItems.Contains(item.Id))
                    {
                        <div style="color: #51cf66; font-weight: 600; margin-top: 10px;">
                            <i class="bi bi-check-circle-fill"></i> Selecionado
                        </div>
                    }
                </div>
            }
        </div>

        @if (selectedItems.Any())
        {
            <div class="order-summary">
                <h3>Resumo do Pedido</h3>
                @foreach (var itemId in selectedItems)
                {
                    var item = menuItems.First(m => m.Id == itemId);
                    <div class="summary-row">
                        <span>@item.Name</span>
                        <span>R$ @item.Price.ToString("F2")</span>
                    </div>
                }
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>R$ @CalculateSubtotal().ToString("F2")</span>
                </div>
                @if (CalculateDiscount() > 0)
                {
                    <div class="summary-row discount">
                        <span>Desconto (@CalculateDiscountPercentage()%)</span>
                        <span>- R$ @CalculateDiscount().ToString("F2")</span>
                    </div>
                }
                <div class="summary-row total">
                    <span>Total</span>
                    <span>R$ @CalculateTotal().ToString("F2")</span>
                </div>
                
                <button class="btn btn-success" @onclick="CreateOrder" style="width: 100%; margin-top: 20px;">
                    Finalizar Pedido
                </button>
            </div>
        }
    }
</div>

@code {
private List<MenuItemModel> menuItems = new();
private List<Guid> selectedItems = new();
private bool loading = true;
private string? error;
private decimal? lastOrderTotal;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            menuItems = await MenuService.GetMenuAsync();
        }
        catch (Exception ex)
        {
            error = $"Erro ao carregar cardápio: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ToggleItem(MenuItemModel item)
    {
        if (selectedItems.Contains(item.Id))
        {
            selectedItems.Remove(item.Id);
        }
        else
        {
            // Se for sanduíche, remove qualquer outro sanduíche selecionado
            if (item.Type == 0) // Sandwich
            {
                var sandwiches = menuItems.Where(m => m.Type == 0).Select(m => m.Id).ToList();
                selectedItems.RemoveAll(id => sandwiches.Contains(id));
            }
            selectedItems.Add(item.Id);
        }
    }

    private async Task CreateOrder()
    {
        try
        {
            var hasSandwich = selectedItems.Any(id => menuItems.First(m => m.Id == id).Type == 0);
            if (!hasSandwich)
            {
                ToastService.ShowWarning("Atençăo", "Vocę precisa selecionar um sanduíche!");
                return;
            }

            var order = await OrderService.CreateOrderAsync(selectedItems);
            lastOrderTotal = order.Total;
            ToastService.ShowSuccess("Pedido Realizado!", $"Seu pedido foi criado com sucesso! Total: R$ {order.Total:F2}");
            selectedItems.Clear();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Erro ao Criar Pedido", ex.Message);
        }
    }

    private decimal CalculateSubtotal()
    {
        return selectedItems.Sum(id => menuItems.First(m => m.Id == id).Price);
    }

    private int CalculateDiscountPercentage()
    {
        var hasSandwich = selectedItems.Any(id => menuItems.First(m => m.Id == id).Type == 0);
        var hasFries = selectedItems.Any(id => menuItems.First(m => m.Id == id).Type == 1);
        var hasDrink = selectedItems.Any(id => menuItems.First(m => m.Id == id).Type == 2);

        if (hasSandwich && hasFries && hasDrink) return 20;
        if (hasSandwich && hasDrink) return 15;
        if (hasSandwich && hasFries) return 10;
        return 0;
    }

    private decimal CalculateDiscount()
    {
        return CalculateSubtotal() * CalculateDiscountPercentage() / 100;
    }

    private decimal CalculateTotal()
    {
        return CalculateSubtotal() - CalculateDiscount();
    }

    private string GetBadgeClass(int type)
    {
        return type switch
        {
            0 => "badge-sandwich",
            1 => "badge-fries",
            2 => "badge-drink",
            _ => ""
        };
    }

    private string GetTypeLabel(int type)
    {
        return type switch
        {
            0 => "Sanduíche",
            1 => "Fritas",
            2 => "Bebida",
            _ => ""
        };
    }
}
