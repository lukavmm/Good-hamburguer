@page "/orders"
@attribute [Authorize]
@using GoodHamburger.BlazorApp.Services
@using GoodHamburger.BlazorApp.Models
@using Microsoft.AspNetCore.Authorization
@inject IOrderService OrderService
@inject IMenuService MenuService
@inject ToastService ToastService

<PageTitle>Meus Pedidos</PageTitle>

<div class="container">
    <h1><i class="bi bi-clipboard-check-fill" style="font-size: 0.9em;"></i> Meus Pedidos</h1>

    @if (loading)
    {
        <div class="loading">
            <div class="loading-spinner"></div>
            <div class="loading-text">Carregando pedidos...</div>
        </div>
    }
    else if (error != null)
    {
        <div class="error">@error</div>
    }
    else if (!orders.Any())
    {
        <div class="orders-list">
            <div style="text-align: center; padding: 40px;">
                <i class="bi bi-clipboard-x" style="font-size: 5em; color: #ccc; margin-bottom: 20px; display: block;"></i>
                <h3 style="color: #333;">Nenhum pedido encontrado</h3>
                <p style="color: #666;">Faça seu primeiro pedido na página inicial!</p>
                <a href="/" class="btn btn-primary" style="display: inline-block; margin-top: 20px; text-decoration: none;">
                    Fazer Pedido
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
            {
                <div class="order-card">
                    <h3>Pedido #@order.Id.ToString().Substring(0, 8)</h3>
                    <p><strong>Data:</strong> @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    
                    <h4>Itens:</h4>
                    <ul>
                        @foreach (var item in order.Items)
                        {
                            <li>@item.Name - R$ @item.Price.ToString("F2")</li>
                        }
                    </ul>

                    <div class="summary-row">
                        <span>Subtotal:</span>
                        <span>R$ @order.Subtotal.ToString("F2")</span>
                    </div>

                    @if (order.DiscountPercentage > 0)
                    {
                        <div class="summary-row discount">
                            <span>Desconto (@order.DiscountPercentage%):</span>
                            <span>- R$ @order.DiscountAmount.ToString("F2")</span>
                        </div>
                    }

                    <div class="summary-row total">
                        <span>Total:</span>
                        <span>R$ @order.Total.ToString("F2")</span>
                    </div>

                    <div style="display: flex; gap: 10px; margin-top: 15px;">
                        <button class="btn btn-primary" @onclick="() => OpenEditModal(order)" style="flex: 1;">
                            <i class="bi bi-pencil-fill"></i> Editar Pedido
                        </button>
                        <button class="btn btn-danger" @onclick="() => DeleteOrder(order.Id)" style="flex: 1;">
                            <i class="bi bi-trash-fill"></i> Cancelar Pedido
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @if (showEditModal)
    {
        <div class="modal-backdrop" @onclick="CloseEditModal">
            <div class="modal-content" @onclick:stopPropagation="true" style="max-width: 800px;">
                <div class="modal-header">
                    <h2>Editar Pedido #@currentOrder.Id.ToString().Substring(0, 8)</h2>
                    <button class="btn-close" @onclick="CloseEditModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                
                <div class="modal-body">
                    @if (modalError != null)
                    {
                        <div class="error">@modalError</div>
                    }
                    
                    <h4 style="margin-bottom: 15px;">Selecione os itens do pedido:</h4>
                    
                    <div class="menu-grid" style="margin: 20px 0;">
                        @foreach (var item in menuItems)
                        {
                            <div class="menu-item @(selectedItemIds.Contains(item.Id) ? "selected" : "")" 
                                 @onclick="() => ToggleItem(item)" 
                                 style="cursor: pointer;">
                                <span class="badge @GetBadgeClass(item.Type)">@GetTypeLabel(item.Type)</span>
                                <h3 style="font-size: 1.1em;">@item.Name</h3>
                                <div class="price" style="font-size: 1.3em;">R$ @item.Price.ToString("F2")</div>
                                @if (selectedItemIds.Contains(item.Id))
                                {
                                    <div style="color: #51cf66; font-weight: 600; margin-top: 5px; font-size: 0.9em;">
                                        <i class="bi bi-check-circle-fill"></i> Selecionado
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (selectedItemIds.Any())
                    {
                        <div class="order-summary" style="margin-top: 20px;">
                            <h4>Resumo:</h4>
                            @foreach (var itemId in selectedItemIds)
                            {
                                var item = menuItems.First(m => m.Id == itemId);
                                <div class="summary-row">
                                    <span>@item.Name</span>
                                    <span>R$ @item.Price.ToString("F2")</span>
                                </div>
                            }
                            <div class="summary-row">
                                <span>Subtotal</span>
                                <span>R$ @CalculateSubtotal().ToString("F2")</span>
                            </div>
                            @if (CalculateDiscount() > 0)
                            {
                                <div class="summary-row discount">
                                    <span>Desconto (@CalculateDiscountPercentage()%)</span>
                                    <span>- R$ @CalculateDiscount().ToString("F2")</span>
                                </div>
                            }
                            <div class="summary-row total">
                                <span>Total</span>
                                <span>R$ @CalculateTotal().ToString("F2")</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseEditModal">Cancelar</button>
                    <button class="btn btn-success" @onclick="SaveOrder">
                        <i class="bi bi-save"></i> Salvar Alteraçőes
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<OrderModel> orders = new();
    private List<MenuItemModel> menuItems = new();
    private List<Guid> selectedItemIds = new();
    private OrderModel currentOrder = new();
    private bool loading = true;
    private bool showEditModal;
    private string? error;
    private string? modalError;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        await LoadMenu();
    }

    private async Task LoadOrders()
    {
        loading = true;
        error = null;

        try
        {
            orders = await OrderService.GetAllOrdersAsync();
        }
        catch (Exception ex)
        {
            error = $"Erro ao carregar pedidos: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadMenu()
    {
        try
        {
            menuItems = await MenuService.GetMenuAsync();
        }
        catch (Exception ex)
        {
            error = $"Erro ao carregar cardápio: {ex.Message}";
        }
    }

    private void OpenEditModal(OrderModel order)
    {
        currentOrder = order;
        selectedItemIds = order.Items.Select(i => i.Id).ToList();
        showEditModal = true;
        modalError = null;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        modalError = null;
        selectedItemIds.Clear();
    }

    private void ToggleItem(MenuItemModel item)
    {
        if (selectedItemIds.Contains(item.Id))
        {
            selectedItemIds.Remove(item.Id);
        }
        else
        {
            // Se for sanduíche, remove qualquer outro sanduíche selecionado
            if (item.Type == 0) // Sandwich
            {
                var sandwiches = menuItems.Where(m => m.Type == 0).Select(m => m.Id).ToList();
                selectedItemIds.RemoveAll(id => sandwiches.Contains(id));
            }
            selectedItemIds.Add(item.Id);
        }
    }

    private async Task SaveOrder()
    {
        modalError = null;

        var hasSandwich = selectedItemIds.Any(id => menuItems.First(m => m.Id == id).Type == 0);
        if (!hasSandwich)
        {
            modalError = "Vocę precisa selecionar um sanduíche!";
            return;
        }

        try
        {
            await OrderService.UpdateOrderAsync(currentOrder.Id, selectedItemIds);
            ToastService.ShowSuccess("Pedido Atualizado", $"Pedido #...{currentOrder.Id.ToString().Substring(0, 8)} foi atualizado com sucesso!");
            await LoadOrders();
            CloseEditModal();
        }
        catch (Exception ex)
        {
            modalError = $"Erro ao atualizar pedido: {ex.Message}";
            ToastService.ShowError("Erro ao Atualizar", ex.Message);
        }
    }

    private async Task DeleteOrder(Guid orderId)
    {
        try
        {
            await OrderService.DeleteOrderAsync(orderId);
            ToastService.ShowSuccess("Pedido Cancelado", "Seu pedido foi cancelado com sucesso!");
            await LoadOrders();
        }
        catch (Exception ex)
        {
            error = $"Erro ao cancelar pedido: {ex.Message}";
            ToastService.ShowError("Erro ao Cancelar", ex.Message);
        }
    }

    private decimal CalculateSubtotal()
    {
        return selectedItemIds.Sum(id => menuItems.First(m => m.Id == id).Price);
    }

    private int CalculateDiscountPercentage()
    {
        var hasSandwich = selectedItemIds.Any(id => menuItems.First(m => m.Id == id).Type == 0);
        var hasFries = selectedItemIds.Any(id => menuItems.First(m => m.Id == id).Type == 1);
        var hasDrink = selectedItemIds.Any(id => menuItems.First(m => m.Id == id).Type == 2);

        if (hasSandwich && hasFries && hasDrink) return 20;
        if (hasSandwich && hasDrink) return 15;
        if (hasSandwich && hasFries) return 10;
        return 0;
    }

    private decimal CalculateDiscount()
    {
        return CalculateSubtotal() * CalculateDiscountPercentage() / 100;
    }

    private decimal CalculateTotal()
    {
        return CalculateSubtotal() - CalculateDiscount();
    }

    private string GetBadgeClass(int type)
    {
        return type switch
        {
            0 => "badge-sandwich",
            1 => "badge-fries",
            2 => "badge-drink",
            _ => ""
        };
    }

    private string GetTypeLabel(int type)
    {
        return type switch
        {
            0 => "Sanduíche",
            1 => "Fritas",
            2 => "Bebida",
            _ => ""
        };
    }
}
