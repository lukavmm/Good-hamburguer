@page "/register"
@layout AuthLayout
@using GoodHamburger.BlazorApp.Services
@using GoodHamburger.BlazorApp.Models
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>Registrar - GoodHamburger</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <i class="bi bi-person-plus-fill" style="font-size: 3em; color: #667eea;"></i>
            <h1>Criar Conta</h1>
            <p>Preencha os dados para se registrar</p>
        </div>

        <EditForm Model="registerModel" OnValidSubmit="HandleRegister" class="auth-form">
            <DataAnnotationsValidator />

            @if (errorMessage != null)
            {
                <div class="error" style="margin-bottom: 20px;">
                    <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                </div>
            }

            <div class="form-group">
                <label>
                    <i class="bi bi-person-fill"></i>
                    <span>Usuário</span>
                </label>
                <InputText @bind-Value="registerModel.Username" class="form-control" placeholder="Escolha um nome de usuário" />
                <ValidationMessage For="@(() => registerModel.Username)" />
            </div>

            <div class="form-group">
                <label>
                    <i class="bi bi-lock-fill"></i>
                    <span>Senha</span>
                </label>
                <InputText @bind-Value="registerModel.Password" type="password" class="form-control" placeholder="Escolha uma senha" />
                <ValidationMessage For="@(() => registerModel.Password)" />
            </div>

            <div class="form-group">
                <label>
                    <i class="bi bi-shield-fill"></i>
                    <span>Tipo de Usuário</span>
                </label>
                <InputSelect @bind-Value="registerModel.Role" class="form-control">
                    <option value="0">Administrador</option>
                    <option value="1">Usuário Normal</option>
                </InputSelect>
            </div>

            <button type="submit" class="btn btn-success btn-block" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-small"></span>
                    <span>Registrando...</span>
                }
                else
                {
                    <i class="bi bi-check-circle-fill"></i>
                    <span>Criar Conta</span>
                }
            </button>
        </EditForm>

        <div class="auth-footer">
            <p>Já tem uma conta?</p>
            <a href="/login" class="link-primary">
                <i class="bi bi-box-arrow-in-right"></i> Fazer login
            </a>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private bool isLoading;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await AuthService.RegisterAsync(registerModel);
            ToastService.ShowSuccess("Conta criada!", $"Bem-vindo(a), {response.Username}! Faça login para continuar.");
            
            // Redireciona para login
            await Task.Delay(1500);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            errorMessage = "Erro ao criar conta. Tente novamente.";
            ToastService.ShowError("Erro ao registrar", errorMessage);
        }
        finally
        {
            isLoading = false;
        }
    }
}
