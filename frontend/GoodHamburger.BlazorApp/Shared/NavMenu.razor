@using Microsoft.AspNetCore.Components.Authorization
@using GoodHamburger.BlazorApp.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthService AuthService
@inject NavigationManager Navigation

<AuthorizeView Context="authContext">
    <Authorized>
        <nav class="nav-menu">
            <NavLink href="/home" class="nav-link">
                <i class="bi bi-house-fill"></i> InÌcio
            </NavLink>
            <NavLink href="/orders" class="nav-link">
                <i class="bi bi-clipboard-check-fill"></i> Meus Pedidos
            </NavLink>
            <AuthorizeView Roles="Admin" Context="adminContext">
                <Authorized>
                    <NavLink href="/menu-management" class="nav-link">
                        <i class="bi bi-gear-fill"></i> Gerenciar Card·pio
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <div class="nav-user">
                <span class="username">
                    <i class="bi bi-person-circle"></i> @authContext.User.Identity?.Name
                </span>
                <button class="btn-logout" @onclick="HandleLogout">
                    <i class="bi bi-box-arrow-right"></i> Sair
                </button>
            </div>
        </nav>
    </Authorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }
}



